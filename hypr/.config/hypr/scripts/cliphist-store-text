#!/bin/sh

tmp="$(mktemp)"
ignore_file="${XDG_CACHE_HOME:-$HOME/.cache}/hypr-clipboard-ignore-once"
trap 'rm -f "$tmp"' EXIT

cat > "$tmp"

if [ -f "$ignore_file" ]; then
    if cmp -s "$tmp" "$ignore_file"; then
        rm -f "$ignore_file"
        exit 0
    fi
    rm -f "$ignore_file"
fi

if grep -Eq '^[[:space:]]*\[\[ binary data \.\.\. [^]]+ \.\.\. \]\][[:space:]]*$' "$tmp"; then
    exit 0
fi

cliphist store < "$tmp"

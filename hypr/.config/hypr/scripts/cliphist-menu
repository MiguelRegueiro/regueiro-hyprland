#!/bin/sh
CLEAR="Clear all history"
selection=$({ echo "$CLEAR"; cliphist list; } | rofi -dmenu -p "Clipboard" -i)
[ -n "$selection" ] || exit 0
if [ "$selection" = "$CLEAR" ]; then
    cliphist wipe
else
    tmp="$(mktemp)"
    trap 'rm -f "$tmp"' EXIT
    printf '%s' "$selection" | cliphist decode > "$tmp" || exit 1
    mime="$(file --brief --mime-type "$tmp")"
    [ "$mime" = "inode/x-empty" ] && mime="text/plain"
    wl-copy --type "$mime" < "$tmp"
fi

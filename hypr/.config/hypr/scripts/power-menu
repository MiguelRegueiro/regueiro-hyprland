#!/bin/sh

action="${1:-toggle}"

case "$action" in
    menu)
        action="toggle"
        ;;
    poweroff)
        action="shutdown"
        ;;
    restart)
        action="reboot"
        ;;
esac

case "$action" in
    toggle | open | close | lock | suspend | logout | reboot | shutdown)
        exec qs ipc call powermenu "$action"
        ;;
    *)
        printf 'Usage: %s [toggle|open|close|lock|suspend|logout|reboot|shutdown]\n' "$0" >&2
        exit 2
        ;;
esac
